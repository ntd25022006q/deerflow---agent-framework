# Deerflow Agent Framework — EditorConfig
# https://editorconfig.org
#
# This file ensures consistent coding styles across different editors and IDEs.
# All contributors should have EditorConfig support enabled in their editor.

# Top-most EditorConfig file
root = true

# Default settings for all files
[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 2

# Markdown files — preserve trailing whitespace (used for line breaks)
[*.md]
trim_trailing_whitespace = false

# YAML / JSON configuration files
[*.{json,yml,yaml}]
indent_size = 2

# Makefiles require tabs for indentation
[Makefile]
indent_style = tab

# Python files use 4-space indentation (PEP 8)
[*.py]
indent_size = 4

# Shell scripts
[*.sh]
indent_size = 2

# Dockerfiles
[Dockerfile]
indent_size = 2

# XML / HTML files
[*.{xml,html,svg,xhtml}]
indent_size = 2

# CSS / SCSS / Less stylesheets
[*.{css,scss,less,sass}]
indent_size = 2

# Package manifests
[{package.json,package-lock.json,*.gemspec}]
indent_size = 2
